# Test database — port 5433 to avoid clashing with dev (5432)
# POSTGRES_TEST_PASSWORD must match the password in DATABASE_URL below and
# docker-compose.yml's postgres_test service (default: changeme)
DATABASE_URL="postgresql://meridian:changeme@localhost:5433/meridian_test"
JWT_SECRET="test-secret-not-used-in-production"
NODE_ENV=test
ADMIN_INITIAL_PASSWORD=admin123
