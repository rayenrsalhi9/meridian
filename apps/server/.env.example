# App environment (development / production / test)
NODE_ENV=development

# PostgreSQL connection string
DATABASE_URL="postgresql://meridian:changeme@localhost:5432/meridian_dev"

# Admin seed password — optional when NODE_ENV=development (falls back to "admin123"),
# required in all other environments (seed aborts if unset).
# ADMIN_INITIAL_PASSWORD="your-strong-password"

# JWT signing secret — required in all environments.
# WARNING: the value below is a dev placeholder; replace with a strong
# random secret in any non-development environment.
JWT_SECRET="change-me-to-a-strong-random-secret"
