{
  "name": "meridian",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "lint": "oxlint .",
    "format": "prettier --write .",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "oxlint": "^1.74.0",
    "prettier": "^3.9.5"
  }
}
